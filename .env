# Binance API Configuration
# Get your API keys from: https://www.binance.com/en/account/api-management
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# Use testnet first! Only set to false after thorough testing
# Testnet: https://testnet.binance.vision
BINANCE_TESTNET=true

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Database settings (default values work with docker-compose)
DATABASE_URL=postgresql://trader:trader@localhost:5432/trading_bot

# Redis settings
REDIS_URL=redis://localhost:6379/0

# Application settings
DEBUG=false
WORKERS=4
