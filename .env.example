# Trading Bot Configuration Example
# Copy this file to .env and fill in your actual values

# Binance API Configuration
# Get your API keys from: https://www.binance.com/en/account/api-management
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# ⚠️ IMPORTANT: Use TESTNET first!
# Only set to false after thorough testing with real money
# Testnet endpoint: https://testnet.binance.vision
BINANCE_TESTNET=true

# Logging level
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Database Configuration
# With docker-compose, use default values
DATABASE_URL=postgresql://trader:trader@postgres:5432/trading_bot

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# Application Settings
DEBUG=false
WORKERS=4

# Optional: Custom settings
# MAX_POSITION_SIZE=50000  # Max USDT per trade
# MAX_DRAWDOWN=20          # Max portfolio loss %
# MAX_ACTIVE_ORDERS=20     # Max concurrent orders
